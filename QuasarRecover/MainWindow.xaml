<Window x:Class="QuasarRecover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuasarRecover"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#070B14">

    <Window.Resources>
        <SolidColorBrush x:Key="Panel" Color="#111827"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#243244"/>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#38BDF8"/>
        <SolidColorBrush x:Key="AccentDark" Color="#0284C7"/>

        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="22"
                Padding="20"
                BorderBrush="#1E3A5F"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0B253A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="QuasarRecover"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                        <Border Background="#0EA5E9"
                                CornerRadius="12"
                                Padding="8,3"
                                Margin="12,6,0,0">
                            <TextBlock Text="Github.com/AceYonca"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Read-only configuration recovery for owned Quasar client builds"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13"
                               Margin="1,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="OpenAssemblyButton"
                            Content="Open Client EXE"
                            Width="155"
                            Margin="0,0,10,0"
                            Click="OpenAssemblyButton_Click"/>

                    <Button x:Name="AnalyzeButton"
                            Content="Analyze"
                            Width="115"
                            Style="{StaticResource PrimaryButton}"
                            Click="AnalyzeButton_Click"/>

                    <Button x:Name="ExportJsonButton"
                            Content="Export JSON"
                            Width="125"
                            Margin="10,0,0,0"
                            Click="ExportJsonButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="18"
                    Margin="0,0,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Assembly"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Selected file"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,12,0,4"/>

                        <TextBox x:Name="AssemblyPathTextBox"
                                 Height="78"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,22,0,0">
                        <TextBlock Text="Recovery Status"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <Border Background="#0F172A" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <TextBlock x:Name="SettingsStatusText"
                                       Text="● Settings class: Not scanned"
                                       Foreground="#CBD5E1"/>
                        </Border>

                        <Border Background="#0F172A" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <TextBlock x:Name="HostsStatusText"
                                       Text="● Hosts: Not scanned"
                                       Foreground="#CBD5E1"/>
                        </Border>

                        <Border Background="#0F172A" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <TextBlock x:Name="CertificateStatusText"
                                       Text="● Certificate: Not scanned"
                                       Foreground="#CBD5E1"/>
                        </Border>

                        <Border Background="#0F172A" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <TextBlock x:Name="SignatureStatusText"
                                       Text="● Signature: Not scanned"
                                       Foreground="#CBD5E1"/>
                        </Border>

                        <Border Background="#0F172A" CornerRadius="14" Padding="12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Recovered Config"
                                           Foreground="#F8FAFC"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="RecoveredHostsText" Text="Hosts: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RecoveredVersionText" Text="Version: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RecoveredInstallText" Text="Install: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RecoveredMutexText" Text="Mutex: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RecoveredTagText" Text="Tag: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="RecoveredStartupText" Text="Startup key: -" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Background="#07111F"
                            BorderBrush="#1E3A5F"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Safety Mode"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="16"
                                       FontWeight="Bold"/>
                            <TextBlock Text="The selected executable is parsed with dnlib and is never started."
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="14">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="Recovered JSON">
                        <TextBox x:Name="JsonOutputTextBox"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#020617"
                                 Foreground="#D1D5DB"
                                 BorderBrush="#1E293B"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Text="{}"/>
                    </TabItem>

                    <TabItem Header="Log">
                        <TextBox x:Name="LogTextBox"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#020617"
                                 Foreground="#D1D5DB"
                                 BorderBrush="#1E293B"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Text="- Waiting for assembly..."/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2">
            <TextBlock x:Name="FooterStatusText"
                       Text="Ready."
                       Foreground="{StaticResource TextMuted}"
                       VerticalAlignment="Center"/>

            <TextBlock Text="QuasarRecover · read-only dnlib static extractor"
                       Foreground="#475569"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
